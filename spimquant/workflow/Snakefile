rule all_group_stats:
    """Target rule for group-level statistical analysis."""
    input:
        # Per-contrast groupstats TSV and PNG
        expand(
            bids(
                root=group_stats_root,
                seg="{seg}",
                from_="{template}",
                desc="{desc}",
                contrast="{pairwise_contrast}",
                suffix="groupstats.{ext}",
            ),
            seg=atlas_segs,
            desc=config["seg_method"],
            template=config["template"],
            pairwise_contrast=pairwise_contrast_labels,
            ext=["png", "tsv"],
        ),
        # Per-contrast NIfTI stat maps for each seg metric
        expand(
            bids(
                root=group_stats_root,
                seg="{seg}",
                space="{template}",
                desc="{desc}",
                contrast="{pairwise_contrast}",
                metric="{stain}+{metric}",
                suffix="{stat}.nii.gz",
            ),
            seg=atlas_segs,
            desc=config["seg_method"],
            template=config["template"],
            stain=stains_for_seg,
            metric=config["seg_metrics"],
            stat=config["stats_maps"],
            pairwise_contrast=pairwise_contrast_labels,
        ),
        # All-subjects count maps (not contrast-specific)
        expand(
            bids(
                root=group_stats_root,
                level="{level}",
                space="{template}",
                desc="{desc}",
                suffix="{stain}+count.nii.gz",
            ),
            desc=config["seg_method"],
            template=config["template"],
            level=range(4),
            stain=stains_for_seg,
        ),


rule all_group_stats_coloc:
    input:
        # Per-contrast NIfTI stat maps for coloc metrics
        expand(
            bids(
                root=group_stats_root,
                seg="{seg}",
                space="{template}",
                desc="{desc}",
                contrast="{pairwise_contrast}",
                metric="coloc+{metric}",
                suffix="{stat}.nii.gz",
            ),
            seg=atlas_segs,
            desc=config["seg_method"],
            template=config["template"],
            metric=config["coloc_seg_metrics"],
            stat=config["stats_maps"],
            pairwise_contrast=pairwise_contrast_labels,
        ),
        # All-subjects colocalization count maps (not contrast-specific)
        expand(
            bids(
                root=group_stats_root,
                space="{template}",
                level="{level}",
                desc="{desc}",
                suffix="coloccount.nii.gz",
            ),
            desc=config["seg_method"],
            template=config["template"],
            level=range(4),
        ),


rule all_qc:
    """Target rule for subject-level visual QC outputs."""
    input:
        # Intensity histograms for every stain channel
        inputs["spim"].expand(
            bids(
                root=root,
                datatype="qc",
                stain="{stain}",
                suffix="histogram.png",
                **inputs["spim"].wildcards,
            ),
            stain=stains,
        ),
        # Segmentation overview figures (per stain, per seg method)
        inputs["spim"].expand(
            bids(
                root=root,
                datatype="qc",
                stain="{stain}",
                desc="{desc}",
                suffix="segslices.png",
                **inputs["spim"].wildcards,
            ),
            stain=stains_for_seg,
            desc=config["seg_method"],
        )
        if do_seg
        else [],
        # Segmentation ROI zoom montage (per stain, per atlas, per seg method)
        inputs["spim"].expand(
            bids(
                root=root,
                datatype="qc",
                seg="{seg}",
                from_="{template}",
                stain="{stain}",
                desc="{desc}",
                suffix="roimontage.png",
                **inputs["spim"].wildcards,
            ),
            seg=atlas_segs,
            template=config["template"],
            stain=stains_for_seg,
            desc=config["seg_method"],
        )
        if do_seg
        else [],
        # Segmentation ROI zoom montage - no mask overlay
        inputs["spim"].expand(
            bids(
                root=root,
                datatype="qc",
                seg="{seg}",
                from_="{template}",
                stain="{stain}",
                desc="{desc}nomask",
                suffix="roimontage.png",
                **inputs["spim"].wildcards,
            ),
            seg=atlas_segs,
            template=config["template"],
            stain=stains_for_seg,
            desc=config["seg_method"],
        )
        if do_seg
        else [],
        # Vessel overview figures
        inputs["spim"].expand(
            bids(
                root=root,
                datatype="qc",
                stain="{stain}",
                desc="{desc}",
                suffix="vesselslices.png",
                **inputs["spim"].wildcards,
            ),
            stain=stain_for_vessels,
            desc=config["vessel_seg_method"],
        )
        if do_vessels
        else [],
        # Vessel ROI zoom montage (per atlas)
        inputs["spim"].expand(
            bids(
                root=root,
                datatype="qc",
                seg="{seg}",
                from_="{template}",
                stain="{stain}",
                desc="{desc}",
                suffix="vesselroimontage.png",
                **inputs["spim"].wildcards,
            ),
            seg=atlas_segs,
            template=config["template"],
            stain=stain_for_vessels,
            desc=config["vessel_seg_method"],
        )
        if do_vessels
        else [],
        # Vessel ROI zoom montage - no mask overlay
        inputs["spim"].expand(
            bids(
                root=root,
                datatype="qc",
                seg="{seg}",
                from_="{template}",
                stain="{stain}",
                desc="{desc}nomask",
                suffix="vesselroimontage.png",
                **inputs["spim"].wildcards,
            ),
            seg=atlas_segs,
            template=config["template"],
            stain=stain_for_vessels,
            desc=config["vessel_seg_method"],
        )
        if do_vessels
        else [],
        # Z-profile QC (per stain, per seg method)
        inputs["spim"].expand(
            bids(
                root=root,
                datatype="qc",
                stain="{stain}",
                desc="{desc}",
                suffix="zprofile.png",
                **inputs["spim"].wildcards,
            ),
            stain=stains_for_seg,
            desc=config["seg_method"],
        )
        if do_seg
        else [],
        # Object-level statistics (per stain, per seg method)
        inputs["spim"].expand(
            bids(
                root=root,
                datatype="qc",
                stain="{stain}",
                desc="{desc}",
                suffix="objectstats.png",
                **inputs["spim"].wildcards,
            ),
            stain=stains_for_seg,
            desc=config["seg_method"],
        )
        if do_seg
        else [],
        # Per-ROI summary (per atlas seg, per seg method)
        inputs["spim"].expand(
            bids(
                root=root,
                datatype="qc",
                seg="{seg}",
                from_="{template}",
                desc="{desc}",
                suffix="roisummary.png",
                **inputs["spim"].wildcards,
            ),
            seg=atlas_segs,
            template=config["template"],
            desc=config["seg_method"],
        )
        if do_seg
        else [],
        # Instance-centred animated GIFs (per stain, per atlas seg, per seg method)
        inputs["spim"].expand(
            [
                bids(
                    root=root,
                    datatype="qc",
                    seg="{seg}",
                    from_="{template}",
                    stain="{stain}",
                    desc="{desc}",
                    suffix="instancerandom.gif",
                    **inputs["spim"].wildcards,
                ),
                bids(
                    root=root,
                    datatype="qc",
                    seg="{seg}",
                    from_="{template}",
                    stain="{stain}",
                    desc="{desc}",
                    suffix="instancesorted.gif",
                    **inputs["spim"].wildcards,
                ),
            ],
            seg=atlas_segs,
            template=config["template"],
            stain=stains_for_seg,
            desc=config["seg_method"],
        )
        if do_seg and config["qc_instance_seg"]
        else [],
        # Colocalization instance GIFs (per atlas seg, per seg method)
        inputs["spim"].expand(
            [
                bids(
                    root=root,
                    datatype="qc",
                    seg="{seg}",
                    from_="{template}",
                    desc="{desc}",
                    suffix="colocinstancerandom.gif",
                    **inputs["spim"].wildcards,
                ),
                bids(
                    root=root,
                    datatype="qc",
                    seg="{seg}",
                    from_="{template}",
                    desc="{desc}",
                    suffix="colocinstancesorted.gif",
                    **inputs["spim"].wildcards,
                ),
            ],
            seg=atlas_segs,
            template=config["template"],
            desc=config["seg_method"],
        )
        if do_coloc and config["qc_instance_seg"]
        else [],


rule all_tabular_sidecars:
    """Target rule for JSON sidecar files alongside all non-temp tabular outputs."""
    input:
        # --- participant-level TSV sidecars ---
        inputs["spim"].expand(
            bids(
                root=root,
                datatype="tabular",
                seg="{seg}",
                from_="{template}",
                desc="{desc}",
                suffix="mergedsegstats.json",
                **inputs["spim"].wildcards,
            ),
            seg=atlas_segs,
            desc=config["seg_method"],
            template=config["template"],
        )
        if do_seg
        else [],
        inputs["spim"].expand(
            bids(
                root=root,
                datatype="tabular",
                seg="{seg}",
                from_="{template}",
                stain="{stain}",
                level=config["registration_level"],
                desc="{desc}",
                suffix="regionpropstats.json",
                **inputs["spim"].wildcards,
            ),
            seg=atlas_segs,
            desc=config["seg_method"],
            template=config["template"],
            stain=stains_for_seg,
        )
        if do_seg
        else [],
        # --- participant-level parquet sidecars ---
        inputs["spim"].expand(
            bids(
                root=root,
                datatype="tabular",
                desc="{desc}",
                space="{template}",
                suffix="regionprops.json",
                **inputs["spim"].wildcards,
            ),
            desc=config["seg_method"],
            template=config["template"],
        )
        if do_seg
        else [],
        inputs["spim"].expand(
            bids(
                root=root,
                datatype="tabular",
                desc="{desc}",
                space="{template}",
                suffix="coloc.json",
                **inputs["spim"].wildcards,
            ),
            desc=config["seg_method"],
            template=config["template"],
        )
        if do_coloc
        else [],


rule all_group_stats_tabular_sidecars:
    """Target rule for JSON sidecar files alongside all non-temp tabular outputs."""
    input:
        # --- per-contrast group-level TSV sidecars ---
        expand(
            bids(
                root=group_stats_root,
                seg="{seg}",
                from_="{template}",
                desc="{desc}",
                contrast="{pairwise_contrast}",
                suffix="groupstats.json",
            ),
            seg=atlas_segs,
            desc=config["seg_method"],
            template=config["template"],
            pairwise_contrast=pairwise_contrast_labels,
        )
        if do_seg and pairwise_contrast_labels
        else [],
        # --- merged all-subjects TSV sidecars ---
        expand(
            bids(
                root=group_stats_root,
                seg="{seg}",
                from_="{template}",
                desc="{desc}",
                suffix="allsubjects.json",
            ),
            seg=atlas_segs,
            desc=config["seg_method"],
            template=config["template"],
        )
        if do_seg
        else [],
        # --- group-level parquet sidecars ---
        expand(
            bids(
                root=group_stats_root,
                space="{template}",
                desc="{desc}",
                suffix="regionprops.json",
            ),
            desc=config["seg_method"],
            template=config["template"],
        )
        if do_seg
        else [],
        expand(
            bids(
                root=group_stats_root,
                space="{template}",
                desc="{desc}",
                suffix="coloc.json",
            ),
            desc=config["seg_method"],
            template=config["template"],
        )
        if do_coloc
        else [],


rule all_group_merged_tsvs:
    """Target rule for group-level merged all-subjects TSV files."""
    input:
        # Merged segstats TSV (all subjects, no contrast) – always produced
        expand(
            bids(
                root=group_stats_root,
                seg="{seg}",
                from_="{template}",
                desc="{desc}",
                suffix="allsubjects.tsv",
            ),
            seg=atlas_segs,
            desc=config["seg_method"],
            template=config["template"],
        )
        if do_seg
        else [],


rule all_participant:
    default_target: True
    input:
        rules.all_register.input,
        rules.all_vessels.input if do_vessels else [],
        rules.all_segment.input if do_seg else [],
        rules.all_mri_reg.input if config["register_to_mri"] else [],
        rules.all_segment_coloc.input if do_coloc else [],
        rules.all_qc.input,
        rules.all_tabular_sidecars.input,


rule all_group:
    input:
        rules.all_group_merged_tsvs.input,
        rules.all_group_stats.input if do_seg and pairwise_contrast_labels else [],
        rules.all_group_stats_coloc.input
        if do_coloc and pairwise_contrast_labels
        else [],
        rules.all_group_stats_tabular_sidecars.input,


