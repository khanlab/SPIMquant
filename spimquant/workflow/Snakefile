from snakebids import bids, get_wildcard_constraints, set_bids_spec
from snakemake.utils import format
# see details at ./scripts/affine_to_template_nii.py

set_bids_spec("v0_11_0")


configfile: "config/snakebids.yml"
include: "rules/common.smk"
cconfig = CachedConfig(config)


# use expandvars so we can use e.g. '$SLURM_TMPDIR'
root = os.path.expandvars(config["root"])
work = os.path.expandvars(config["work"])


container: config["containers"]["spimprep"]


# wildcard_constraints: **get_wildcard_constraints(config["pybids_inputs"])
wildcard_constraints:
    stain="[a-zA-Z0-9]+",


rule all_templatereg_deform_zooms:
    input:
        spim_zoomed=cconfig.inputs["spim"].expand(
            bids(
                root=root,
                datatype="micr",
                desc="deform",
                space="{template}",
                stain="{stain}",
                res="{res}um",
                suffix="SPIM.nii",
                **cconfig.inputs["spim"].wildcards
            ),
            template=config["template"],
            stain=config["stains"],
            res=config["templatereg"]["zooms"],
        ),


rule all_blobdensity:
    input:
        blob_density=cconfig.inputs["spim"].expand(
            bids(
                root=root,
                datatype="micr",
                space="{template}",
                stain="{stain}",
                suffix="blobdensity.nii",
                **cconfig.inputs["spim"].wildcards
            ),
            stain=config["blobdetect"]["stain"],
            template=config["template"],
        ),


rule all_blobs:
    input:
        spim_zoomed=cconfig.inputs["spim"].expand(
            bids(
                root=root,
                datatype="micr",
                stain="{stain}",
                suffix="blobs.npy",
                **cconfig.inputs["spim"].wildcards
            ),
            stain=config["stains"],
        ),


rule all_templatereg_deform:
    input:
        spim=cconfig.inputs["spim"].expand(
            bids(
                root=root,
                datatype="micr",
                desc="deform",
                space="{template}",
                stain="{stain}",
                suffix="SPIM.nii",
                **cconfig.inputs["spim"].wildcards
            ),
            template=config["template"],
            stain=config["stains"],
        ),


rule all_templatereg_lbl:
    input:
        dseg=cconfig.inputs["spim"].expand(
            bids(
                root=root,
                datatype="micr",
                desc="resampled",
                from_="{template}",
                suffix="dseg.ome.zarr.zip",
                **cconfig.inputs["spim"].wildcards
            ),
            template=config["template"],
        ),


rule all:
    default_target: True
    input:
        rules.all_templatereg_deform.input,


include: "rules/import.smk"
include: "rules/masking.smk"
include: "rules/templatereg.smk"
include: "rules/blobdetect.smk"
include: "rules/cellsegment.smk"
include: "rules/experiment.smk"
