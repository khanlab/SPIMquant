configfile: "config/snakebids.yml"


# use expandvars so we can use e.g. '$SLURM_TMPDIR'
root = os.path.expandvars(config["root"])
work = os.path.expandvars(config["work"]) if config["work"] is not None else root

# Each group-stats invocation writes into its own subfolder so that different
# models / filters / cohorts do not overwrite each other.
group_stats_label = config.get("group_stats_label", "1")
group_stats_root = os.path.join(root, "group", group_stats_label)

# OME-Zarr store format: 'ome.zarr' (directory) or 'ozx' (zip file)
zarr_store_ext = config.get("zarr_store_ext", "ozx")

# Configure chunking and sharding for zarrnii output storage options
_zarr_chunks = config.get("zarr_store_chunks", [1, 128, 128, 128])
_zarr_shards = config.get("zarr_store_shards", None)

config.setdefault("zarrnii_out_kwargs", {}).setdefault("storage_options", {})[
    "chunks"
] = tuple(_zarr_chunks)

# Sharding is not supported with the ozx (zip) format
if zarr_store_ext != "ozx" and _zarr_shards is not None:
    config["zarrnii_out_kwargs"]["storage_options"]["shards"] = tuple(_zarr_shards)


# Get input wildcards
inputs = generate_inputs(
    bids_dir=config["bids_dir"],
    pybids_inputs=config["pybids_inputs"],
    pybidsdb_dir=config.get("pybidsdb_dir"),
    pybidsdb_reset=config.get("pybidsdb_reset"),
    derivatives=config.get("derivatives", None),
    participant_label=config.get("participant_label", None),
    exclude_participant_label=config.get("exclude_participant_label", None),
    validate=not config.get("plugins.validator.skip", False),
    limit_to=["spim", "mri"] if config["register_to_mri"] else ["spim"],
)


if "mri" in inputs:
    suffixes = inputs["mri"].entities["suffix"]
    if len(suffixes) == 1:
        if "." in suffixes[0]:
            mri_suffix = suffixes[0].split(".")[0]
        else:
            mri_suffix = suffixes[0]
    elif len(suffixes) == 0:
        raise ValueError(f"No MRI suffix found, check bids filters")
    else:
        raise ValueError(
            f"More than one MRI suffix found, use --filter-mri to narrow your search: {suffixes}"
        )
else:
    mri_suffix = "T2w"


include: "rules/common.smk"


# prepopulate json sidecar metadata for every spim input
spim_json_overrides = {
    str(spim_path): get_spim_json_overrides(spim_path)
    for spim_path in inputs["spim"].expand()
}
zarrnii_cli_kwargs = {}


def get_zarrnii_in_kwargs(wildcards, input):
    spim_input = getattr(input, "spim", None)
    if spim_input is None:
        # Some rules may pass positional input lists; use the first entry as SPIM input.
        if len(input) == 0:
            raise ValueError(
                f"Unable to resolve SPIM input path for zarrnii kwargs for wildcards: {wildcards}."
                "Make sure the zarrnii input for the rule is named spim, or is the first positional input."
            )
        spim_input = input[0]
    spim_path = str(spim_input)
    kwargs = dict(spim_json_overrides.get(spim_path, {}))
    # CLI options are highest precedence and intentionally override sidecar values.
    kwargs.update(zarrnii_cli_kwargs)
    return kwargs


zarrnii_in_kwargs = get_zarrnii_in_kwargs

if config["sample_staining"]:
    print(f"Using sample_staining override at data import: {config['sample_staining']}")
    stains = config["sample_staining"]
    zarrnii_cli_kwargs["set_channel_labels"] = stains
else:
    stains = get_stains_all_subjects(ignore_stains=config["ignore_stains"])


if config["orientation"]:
    print(f"Using orientation to override at data import: {config['orientation']}")
    zarrnii_cli_kwargs["orientation"] = config["orientation"]

stain_for_reg = None

template = config["templates"][config["template"]]

via_template = config.get("via_template", None)

if via_template is not None:
    if via_template == config["template"]:
        raise ValueError(
            f"--via-template ({via_template}) must be different from --template ({config['template']})"
        )
    if via_template not in config["templates"]:
        raise ValueError(
            f"--via-template ({via_template}) not found in configured templates: "
            f"{list(config['templates'].keys())}"
        )


# first, check if there are any SPIM templates defined
# for the stains we have
use_spim_template = False
spim_templates = template.get("spim_templates", None)

if spim_templates is not None:
    for stain in spim_templates.keys():
        if stain in stains:
            stain_for_reg = stain
            use_spim_template = True
            break

if not use_spim_template:
    for stain in config["stains_for_reg"]:
        if stain in stains:
            stain_for_reg = stain
            break

if stain_for_reg is None:
    raise ValueError(f"a stain for registration was not found in {stains}")


stains_for_seg = sorted(list(set(config["stains_for_seg"]).intersection(set(stains))))

# seg methods that use multi-Otsu thresholding (otsu+k{}i{} pattern)
otsu_seg_methods = [m for m in config["seg_method"] if m.startswith("otsu+")]

# seg methods that use GMM tail-thresholding (gmm+n{}k{} pattern)
gmm_seg_methods = [m for m in config["seg_method"] if m.startswith("gmm+")]

if len(stains_for_seg) == 0 or config["no_segmentation"]:
    do_seg = False
    do_coloc = False
else:
    do_seg = True
    do_coloc = len(stains_for_seg) > 1


stain_for_vessels = None

if config["no_vessels"]:
    do_vessels = False
else:
    for stain in config["stains_for_vessels"]:
        if stain in stains:
            stain_for_vessels = stain
            do_vessels = True
            break

    if stain_for_vessels is None:
        do_vessels = False


# atlas segmentations to use

if config["atlas_segs"] is None:
    atlas_segs = template.get("default_segs", template["atlases"].keys())
else:
    atlas_segs = []
    for seg in config["atlas_segs"]:
        if seg not in template["atlases"]:
            raise ValueError(
                f"Chosen segmentation {seg} was not found in the template {template}"
            )
        else:
            atlas_segs.append(seg)

# atlas segmentations to use for patches (defaults to roi22)
patch_atlas_segs = []
for seg in config["patch_atlas_segs"]:
    if seg not in template["atlases"]:
        raise ValueError(
            f"Chosen patch segmentation {seg} was not found in the template {template}"
        )
    else:
        patch_atlas_segs.append(seg)

# atlas segmentations to use for Imaris crops (defaults to roi22)
crop_atlas_segs = []
for seg in config["crop_atlas_segs"]:
    if seg not in template["atlases"]:
        raise ValueError(
            f"Chosen crop segmentation {seg} was not found in the template {template}"
        )
    else:
        crop_atlas_segs.append(seg)
# Generate pairwise contrast labels from participants.tsv at planning time.
# Contrasts are only enumerated when --group-stats-pairwise is supplied;
# merged group TSVs are always produced at the group analysis level.
pairwise_contrast_labels = []
pairwise_contrast_info = {}  # label -> dict with factor, levelA, levelB, strata

if config.get("analysis_level") == "group":
    _pairwise_factors = config.get("group_stats_pairwise") or []
    _within_factors = config.get("group_stats_within") or []

    if _pairwise_factors:
        if not config.get("group_stats_model"):
            raise ValueError(
                "When --group-stats-pairwise is specified, --group-stats-model must "
                "also be provided (e.g. 'metric ~ C(treatment) + age')."
            )

        _participants_tsv = os.path.join(config["bids_dir"], "participants.tsv")
        if not os.path.exists(_participants_tsv):
            raise ValueError(
                f"participants.tsv not found at '{_participants_tsv}'. "
                "This file is required for group-level analysis."
            )
        _participants_df = _pd.read_csv(_participants_tsv, sep="\t")

        # Apply --group-stats-where filter at planning time so that only the
        # subjects included in the inference cohort are used to enumerate levels.
        _where_expr = config.get("group_stats_where") or None
        if _where_expr:
            _n_before = len(_participants_df)
            try:
                _participants_df = _participants_df.query(_where_expr)
            except Exception as _exc:
                raise ValueError(
                    f"--group-stats-where expression is invalid: {_where_expr}\n"
                    f"Error: {_exc}"
                ) from _exc
            _n_after = len(_participants_df)
            print(
                f"[group-stats-where] Planning-time filter '{_where_expr}': "
                f"{_n_before} rows → {_n_after} rows "
                f"({_n_before- _n_after} excluded)."
            )
            if _n_after == 0:
                raise ValueError(
                    f"--group-stats-where expression '{_where_expr}' excluded all "
                    "rows from participants.tsv. No subjects remain for analysis."
                )

        for _factor in _pairwise_factors:
            if _factor not in _participants_df.columns:
                raise ValueError(
                    f"Pairwise factor '{_factor}' not found in participants.tsv. "
                    f"Available columns: {list(_participants_df.columns)}"
                )
            _levels = sorted(
                str(v) for v in _participants_df[_factor].dropna().unique()
            )

            if len(_levels) < 2:
                raise ValueError(
                    f"Pairwise factor '{_factor}' has fewer than 2 levels after "
                    f"applying --group-stats-where filter. "
                    f"Remaining levels: {_levels}. "
                    "At least 2 levels are required to form a contrast. "
                    "Check --group-stats-where or participants.tsv."
                )

            if _within_factors:
                _within_level_lists = []
                for _wf in _within_factors:
                    if _wf not in _participants_df.columns:
                        raise ValueError(
                            f"Within factor '{_wf}' not found in participants.tsv. "
                            f"Available columns: {list(_participants_df.columns)}"
                        )
                    _within_level_lists.append(
                        sorted(str(v) for v in _participants_df[_wf].dropna().unique())
                    )
                for _lA, _lB in _combinations(_levels, 2):
                    for _stratum in _product(*_within_level_lists):
                        _strata_dict = dict(zip(_within_factors, _stratum))
                        _strata_str = "+".join(
                            f"{f}-{v}" for f, v in _strata_dict.items()
                        )
                        _label = f"{_factor}+{_lA}vs{_lB}+{_strata_str}"
                        pairwise_contrast_labels.append(_label)
                        pairwise_contrast_info[_label] = {
                            "factor": _factor,
                            "levelA": _lA,
                            "levelB": _lB,
                            "strata": _strata_dict,
                        }
            else:
                for _lA, _lB in _combinations(_levels, 2):
                    _label = f"{_factor}+{_lA}vs{_lB}"
                    pairwise_contrast_labels.append(_label)
                    pairwise_contrast_info[_label] = {
                        "factor": _factor,
                        "levelA": _lA,
                        "levelB": _lB,
                        "strata": {},
                    }


wildcard_constraints:
    stain="[a-zA-Z0-9]+",
    pairwise_contrast="[a-zA-Z0-9+_-]+",
    n4_spline="[0-9]+",
    n4_iters="[0-9]+",


