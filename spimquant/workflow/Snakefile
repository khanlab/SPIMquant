rule all_fieldfrac_tune:
    input:
        inputs["spim"].expand(
            bids(
                root=root,
                datatype="seg",
                stain="{stain}",
                level="{level}",
                desc="otsu+k{k}i{i}",
                suffix="fieldfrac.nii.gz",
                **inputs["spim"].wildcards,
            ),
            stain=stains_for_seg,
            level=config["registration_level"],
            k=4,
            i=range(4),
        ),


rule all_otsu_hist_qc:
    """Target rule to generate otsu threshold sweep QC HTML reports.

    Produces one HTML report per subject/stain/method combination for every
    otsu+k{}i{} segmentation method.  Each report shows the multi-Otsu
    histogram alongside 2D crops at a sweep of threshold values so that the
    optimal threshold can be identified visually.  Only meaningful when the
    active ``seg_method`` contains at least one ``otsu+k{}i{}`` entry.
    """
    input:
        inputs["spim"].expand(
            bids(
                root=root,
                datatype="qc",
                stain="{stain}",
                desc="{desc}",
                suffix="otsuthreshqc.html",
                **inputs["spim"].wildcards,
            ),
            stain=stains_for_seg,
            desc=otsu_seg_methods,
        )
        if (do_seg and len(otsu_seg_methods) > 0)
        else [],


# Grid search values for N4 parameter tuning
_tune_n4_spline_spacings = [str(s) for s in [1, 2, 3, 4, 5]]
_tune_n4_iters_list = [str(i) for i in [50, 100, 200]]


rule all_n4_tune:
    """Target rule for N4 bias field correction parameter tuning.

    Runs N4BiasFieldCorrection with a grid search over spline spacing
    (1, 2, 3, 4, 5 mm) and iterations per level (50, 100, 200).  Produces one
    HTML report per subject/stain showing visual comparisons (uncorrected,
    bias field, corrected) and a quantitative summary table for all parameter
    combinations.  PNG figures and the HTML report are written to the ``qc``
    datatype folder for each subject.

    Invoke with: ``spimquant <bids_dir> <out_dir> tune_n4``
    """
    input:
        inputs["spim"].expand(
            bids(
                root=root,
                datatype="qc",
                stain="{stain}",
                suffix="n4tunereport.html",
                **inputs["spim"].wildcards,
            ),
            stain=stains,
        ),


rule all_register:
    input:
        inputs["spim"].expand(
            bids(
                root=root,
                datatype="micr",
                stain="{stain}",
                level="{level}",
                space="{template}",
                suffix="SPIM.nii.gz",
                **inputs["spim"].wildcards,
            ),
            stain=[stain_for_reg],
            level=config["registration_level"],
            template=config["template"],
        ),
        inputs["spim"].expand(
            bids(
                root=root,
                datatype="xfm",
                stain="{stain}",
                from_="SPIM",
                to="{template}",
                suffix="regqc.html",
                **inputs["spim"].wildcards,
            ),
            stain=stain_for_reg,
            template=config["template"],
        ),


rule all_vessels:
    input:
        inputs["spim"].expand(
            bids(
                root=root,
                datatype="vessels",
                stain="{stain}",
                level="{level}",
                desc="{desc}",
                space="{template}",
                suffix="fieldfrac.nii.gz",
                **inputs["spim"].wildcards,
            ),
            level=config["registration_level"],
            template=config["template"],
            desc=config["vessel_seg_method"],
            stain=stain_for_vessels,
        ),
        inputs["spim"].expand(
            bids(
                root=root,
                datatype="vessels",
                stain="{stain}",
                level="{level}",
                desc="{desc}+skeleton",
                suffix="graph.parquet",
                **inputs["spim"].wildcards,
            ),
            level=config["segmentation_level"],
            desc=config["vessel_seg_method"],
            stain=stain_for_vessels,
        ),
        inputs["spim"].expand(
            bids(
                root=root,
                datatype="vessels",
                stain="{stain}",
                level="{level}",
                desc="{desc}+skeleton",
                suffix="nodes.parquet",
                **inputs["spim"].wildcards,
            ),
            level=config["segmentation_level"],
            desc=config["vessel_seg_method"],
            stain=stain_for_vessels,
        ),
        inputs["spim"].expand(
            bids(
                root=root,
                datatype="vessels",
                stain="{stain}",
                level="{level}",
                desc="{desc}+skeleton",
                suffix="edges.parquet",
                **inputs["spim"].wildcards,
            ),
            level=config["segmentation_level"],
            desc=config["vessel_seg_method"],
            stain=stain_for_vessels,
        ),


